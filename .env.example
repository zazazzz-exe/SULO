# SULO client environment (Phase 2 wiring)
# Only EXPO_PUBLIC_* vars are exposed to the app bundle. Never put secret keys
# here — real provider keys live server-side and are added in Phase 2.
# In Phase 1 every value is blank, so the service layer runs on mock data.

# Plain-language rewrites, risk classification, Coach answers (LLM backend)
EXPO_PUBLIC_LLM_API_URL=

# Grounded citations / RAG retrieval (vector store)
EXPO_PUBLIC_VECTOR_STORE_URL=

# Document OCR (photo / upload → text)
EXPO_PUBLIC_OCR_API_URL=

# Automatic speech recognition (voice in)
EXPO_PUBLIC_ASR_API_URL=

# Text-to-speech (read aloud / voice out)
EXPO_PUBLIC_TTS_API_URL=
