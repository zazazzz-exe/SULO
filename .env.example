# SULO client environment.
# Only EXPO_PUBLIC_* vars reach the app bundle — never put privileged secrets
# here. Front the model/vector store with your own server (which holds the real
# provider key) and point the URLs below at that gateway.
#
# EVERY VALUE IS OPTIONAL. With a var unset, that capability falls back to an
# on-device / local-corpus path so the app still works:
#   • no LLM        -> answers are composed locally from the bundled legal corpus
#   • no vector URL -> retrieval uses the bundled corpus (local lexical search)
#   • no OCR URL     -> images are OCR'd on-device on web (Tesseract.js)
#   • no ASR URL     -> voice input uses the web Speech API (web only)
#   • no TTS URL     -> "Read aloud" uses web SpeechSynthesis / native expo-speech

# --- Chat LLM (OpenAI-compatible /chat/completions, streaming) ---
EXPO_PUBLIC_LLM_API_URL=
# Optional bearer token for your gateway (only if a public, rate-limited key is OK)
EXPO_PUBLIC_LLM_API_KEY=
# Model name your gateway expects (default: sulo-legal)
EXPO_PUBLIC_LLM_MODEL=

# --- Retrieval (RAG) ---
# POST { query, top_k } -> { matches: [{ id, score, text, source, label }] }
EXPO_PUBLIC_VECTOR_STORE_URL=
# Optional separate embeddings endpoint (if your vector store needs query vectors)
EXPO_PUBLIC_EMBEDDINGS_API_URL=

# --- Document capture ---
# Multipart { file } -> { text }. Needed for native OCR and digital-PDF parsing.
EXPO_PUBLIC_OCR_API_URL=

# --- Voice ---
# Multipart { file, language } -> { text, confidence }. Used on native (web uses Web Speech).
EXPO_PUBLIC_ASR_API_URL=
# Optional hosted TTS (web/native use platform speech by default).
EXPO_PUBLIC_TTS_API_URL=

# --- Tunables (optional) ---
EXPO_PUBLIC_RAG_TOP_K=4
EXPO_PUBLIC_REQUEST_TIMEOUT_MS=30000
